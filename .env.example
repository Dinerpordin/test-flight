# --- DUFFEL API (REQUIRED) ---
# Get from https://app.duffel.com/ → Access tokens
# Use duffel_live_... for production (live mode)
# Previously duffel_test_... for development/sandbox
DUFFEL_ACCESS_TOKEN=duffel_live_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# --- REDIS CACHE (for 5-15 min price caching - free tier works) ---
# Use Upstash (free) or Redis Cloud
REDIS_URL=redis://default:your-redis-password@your-upstash-url.upstash.io:6379

# --- DATABASE (Supabase or Neon - free tier fine) ---
DATABASE_URL="postgresql://user:pass@your-db-url"

# --- NEXTAUTH / AUTH (optional for price alerts) ---
NEXTAUTH_SECRET=super-long-random-string-here
NEXTAUTH_URL=https://your-production-domain.com

# --- EMAIL (Resend or similar for confirmations/alerts) ---
RESEND_API_KEY=re_XXXXXXXXXXXXXXX

# --- STRIPE (if you want full payments later) ---
STRIPE_SECRET_KEY=sk_live_...

# --- MARKUP ---
# Percentage markup applied to Duffel prices (default: 6)
MARKUP_PERCENTAGE=6
